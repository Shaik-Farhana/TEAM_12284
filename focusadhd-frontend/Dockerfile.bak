# Stage 1: Build Image
FROM node:20-alpine AS build

# Set work directory
WORKDIR /app

# Install dependencies
COPY package*.json ./
RUN npm ci

# Copy sources
COPY . .

# Set build-time variables (default to local if not provided)
ARG VITE_API_BASE_URL
ARG VITE_SUPABASE_URL
ARG VITE_SUPABASE_ANON_KEY

# Set ENV for build
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL
ENV VITE_SUPABASE_URL=$VITE_SUPABASE_URL
ENV VITE_SUPABASE_ANON_KEY=$VITE_SUPABASE_ANON_KEY

# Build the application
RUN npm run build

# Stage 2: Serve with Nginx
FROM nginx:stable-alpine

# Set non-root user (Standard for Cloud Run best practices)
# However, Cloud Run defaults to port 8080. Nginx typically uses 80.
# We configured Nginx to listen on 8080 in nginx.conf

# Copy build output to Nginx directory
COPY --from=build /app/dist /usr/share/nginx/html

# Copy Nginx config
COPY nginx.conf /etc/nginx/conf.d/default.conf

# Expose port
EXPOSE 8080

# Run Nginx
CMD ["nginx", "-g", "daemon off;"]
